#include <iostream>
#include <vector>
#include <optional>
#include <limits>
#include <iomanip>

using namespace std;

// Estructuras de datos
using Solucion = optional<vector<vector<int>>>;
struct ResultadoBT {
    double voa;
    Solucion soa;
};

// Variables globales auxiliares
vector<vector<int>> B; // Matriz de Beneficios: B[trabajador][tarea]
vector<int> capacidadTrabajador;
vector<vector<int>> s;
vector<int> asignadas;
int beneficio_actual = 0;
int tarea;
int trabajador;
vector<int> ultimo;

// --- FUNCIONES DEL ALGORITMO ---

void leerMatriz(int trabajador, int tarea){
    B.assign(trabajador, vector<int>(tarea));
    for( int i = 0; i < trabajador; i++){
        int ultima_tarea;
        for( int j = 0; j < tarea; j++){
            cin >> B[i][j];
            if (B[i][j] != 0 ){
                ultima_tarea = j;
            }
        }
        ultimo[i] = ultima_tarea;   
    }
}

void leerCapacidades(int trabajador){
    for( int i = 0; i < trabajador; i++){
        cin >> capacidadTrabajador[i]; 
    }
}
void inicializar(int trabajador, int tarea){
    ultimo.resize(trabajador);
    leerMatriz(trabajador, tarea);
    leerCapacidades(trabajador);
    asignadas.assign(tarea, 0);
    s.assign(trabajador, vector<int>);
    for( int i = 0; i < trabajador; i++){
        s[i].assign(capacidadTrabajador(i), -1);
    }
}
int numeroTareas( vector<int> vector){
    int contador = 0;
    while ( contador < vector.size() && vector[contador] != -1){
        contador++;
    }
    return contador;
}
int encontrarTarea( int nivel, int indice_inicio){ 
    while( indice_inicio < tarea && B[nivel][indice_inicio] == 0){
        indice_inicio++;
    }
    if( indice_inicio == tarea ){
        return -1;
    }else{
        return indice_inicio;
    }
}
void añadirTarea(int nivel, int indice_tarea){
    int i = 0
    while(i < s[nivel].size() && s[nivel][i] != -1){
         i++;
    }
    if( i < s[nivel].size()){
        s[nivel][i] = indice_tarea;
    }
}
bool sabe_todas_tareas(int nivel){
    for ( int i = 0; i < s[nivel].size(); i++){
        if ( s[nivel] == -1 ){
            break;
        }
        if( B[nivel][s[nivel]] == 0){
            return false;
        }
    }
    return true;
}
void generar(int nivel) {
    int numeroTareas = numeroTareas(s[nivel]);
    int indice_tarea;
    if ( numeroTareas < capacidadTrabajador[nivel] ){
        indice_tarea = encontrarTarea(nivel, numeroTareas);
    }else{
        if ( s[nivel][1] - s[nivel][0] == ((tarea - numeroTareas) / s[nivel][0]) ){ //no quedan mas combinaciones posibles empezando por el valor s[nivel][0]
            indice_tarea = encontrarTarea(nivel, s[nivel][0] + 1);
            s[nivel].assign(s[nivel].size(), -1);
            numeroTareas = 0;  
        }else{  //quedan mas combinaciones posibles empezando por el valor s[nivel][0]
            int ultima_tarea = s[nivel].back();
            indice_tarea = encontrarTarea(nivel, ultima_tarea + 1);
            numeroTareas--;
        }

    }
    if( indice_tarea != -1){
            s[nivel][numeroTareas] = indice_tarea;
            beneficio_actual += B[nivel][indice_tarea];
        }











    if (s[nivel] != -1) {
        asignadas[s[nivel]] -= 1;
        beneficio_actual -= B[nivel][s[nivel]];
    }
    s[nivel] += 1;
    while ( s[nivel] < tarea && B[nivel][s[nivel]] != 0 ){ //buscar tarea que el trabajador (nivel) sepa hacer
        s[nivel]++;
    }
    beneficio_actual += B[nivel][s[nivel]]; //añadir beneficio de esa tarea
    asignadas[s[nivel]] += 1; //asignar la tarea
}

bool solucion(int nivel) {
    return asignadas[s[nivel]] == 1 && nivel == trabajador - 1 && sabe_todas_tareas(nivel);
}

bool criterio(int nivel, double voa) {
    return asignadas[s[nivel]] == 1 && nivel < tarea - 1 && sabe_todas_tareas(nivel);
}

bool masHermanos(int nivel) {
    
    return ;
}

void retroceder(int &nivel) {
    asignadas[s[nivel]] -= 1;
    beneficio_actual -= B[nivel][s[nivel]];
    s[nivel] = -1;
    nivel--;
}

// --- ESQUEMA GENERAL ---

ResultadoBT backtracking_optimizacion_maximizar() {
    int nivel = 0;
    int voa = -numeric_limits<double>::infinity();
    Solucion soa = nullopt;

    cout << "--- INICIO DEL ALGORITMO ---" << endl;

    while (nivel != -1) {
        generar(nivel);
        
        cout << "Nivel: " << nivel << " | Tarea: " << s[nivel] 
             << " | Beneficio: " << beneficio_actual << " | Mejor VOA: " << (voa == -numeric_limits<double>::infinity() ? 0 : voa) << endl;

        if (solucion(nivel)) {
            if (beneficio_actual > voa) {
                voa = beneficio_actual;
                soa = s;
                cout << "   >>> NUEVA MEJOR SOLUCION! Beneficio: " << voa << endl;
            }
        }

        if (criterio(nivel, voa)) {
            nivel++;
        } else {
            while (nivel >= 0 && !masHermanos(nivel)) {
                cout << "   <<< Retrocediendo desde nivel " << nivel << endl;
                retroceder(nivel);
            }
        }
    }
    return {voa, soa};
}

int main() {
    ResultadoBT resultado = backtracking_optimizacion_maximizar();

    cout << "\n--- RESULTADO FINAL ---" << endl;
    if (resultado.soa) {
        cout << "Mejor Beneficio: " << resultado.voa << endl;
        for (int i = 0; i < (int)B.size(); ++i) {
            cout << "  Trabajador " << i << " -> Tarea " << (*resultado.soa)[i] << endl;
        }
    }
    return 0;
}
